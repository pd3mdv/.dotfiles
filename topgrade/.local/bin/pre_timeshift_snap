#!/usr/bin/env bash
set -euo pipefail

MARKER="topgrade-auto"
COMMENT="$MARKER $(date '+%Y-%m-%d %H:%M:%S')"

echo "Creating Timeshift snapshot..."
sudo timeshift --create --comments "$COMMENT" --tags O --scripted

echo "Removing older Topgrade Timeshift snapshots..."
mapfile -t OLD_SNAPSHOTS < <(
sudo timeshift --list |
awk -v marker="$MARKER" '$0 ~ marker {
	for (i=1; i<=NF; i++) {
		if ($i ~ /^[0-9]{4}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}$/) {
			print $i
		}
	}
}' | sort -r | tail -n +2)

for snap in "${OLD_SNAPSHOTS[@]}"; do
	echo "Deleting old snapshot: $snap"
	sudo timeshift --delete --snapshot "$snap" --yes --scripted
done
